<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SERV RISC-V — Hardware Studio</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #0d0f1a; color: #fff; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        h2 { color: #9cdcfe; margin-top: 0; font-family: monospace; letter-spacing: 1px; }
        
        .toolbar { display: flex; gap: 10px; width: 100%; max-width: 1200px; margin-bottom: 20px; flex-wrap: wrap; }
        button { padding: 12px 20px; font-size: 0.95rem; background: #1565c0; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: background 0.2s; flex: 1; min-width: 150px; }
        button:hover:not(:disabled) { background: #1e88e5; }
        button:disabled { opacity: 0.4; cursor: not-allowed; }
        .btn-run { background: #2e7d32; } .btn-run:hover:not(:disabled) { background: #388e3c; }
        .btn-pause { background: #b08d00; } .btn-pause:hover:not(:disabled) { background: #d4aa00; }
        
        .console-container { display: flex; flex-wrap: wrap; gap: 20px; width: 100%; max-width: 1200px; }
        .panel { background: #1e2030; border: 2px solid #2a3050; border-radius: 8px; padding: 15px; flex: 1 1 400px; box-sizing: border-box; }
        
        /* GBA Screen */
        #screen { background: #000; width: 100%; max-width: 480px; aspect-ratio: 240/160; image-rendering: pixelated; display: block; margin: 0 auto; border: 2px solid #555; }
        .controls-help { color: #888; font-size: 0.85rem; text-align: center; margin-top: 10px; font-family: monospace; }
        
        /* UART Terminal */
        #terminal { background: #000; height: 200px; overflow-y: auto; color: #69db7c; font-size: 1rem; font-family: monospace; white-space: pre-wrap; padding: 10px; border-radius: 4px; box-shadow: inset 0 0 10px rgba(0,0,0,0.8); }
        #uartInput { width: 100%; background: #111; border: 1px solid #444; color: #69db7c; padding: 8px; font-family: monospace; margin-top: 10px; box-sizing: border-box; outline: none; }
        
        /* Code Editor */
        #editor { width: 100%; height: 350px; background: #0d0f1a; color: #ce9178; font-family: monospace; font-size: 1rem; padding: 10px; border: 1px solid #444; border-radius: 4px; box-sizing: border-box; outline: none; resize: vertical; white-space: pre; }
        #editor:focus { border-color: #69db7c; }

        /* Registers Inspector */
        .reg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 4px; background: #111; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 0.85rem; }
        .reg-cell { display: flex; justify-content: space-between; background: #0d0f1a; padding: 4px 8px; border: 1px solid #2a3050; border-radius: 3px; }
        .reg-name { color: #569cd6; font-weight: bold; }
        .reg-val { color: #dcdcaa; }

        /* Memory Inspector */
        .mem-toolbar { display: flex; gap: 10px; margin-bottom: 10px; align-items: center; font-family: monospace; font-size: 0.9rem;}
        .mem-toolbar input { background: #0d0f1a; border: 1px solid #444; color: #9cdcfe; padding: 6px; border-radius: 4px; font-family: monospace; width: 120px;}
        .mem-grid { background: #111; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 0.9rem; }
        .mem-row { display: flex; gap: 10px; align-items: center; margin-bottom: 4px; }
        .mem-addr { color: #888; width: 90px; }
        .mem-cell { background: #0d0f1a; color: #ce9178; border: 1px solid #2a3050; padding: 4px; width: 75px; text-align: center; border-radius: 3px; font-family: monospace; transition: all 0.2s; }
        .mem-cell:focus { outline: none; border-color: #69db7c; color: #69db7c; background: #000; }
    </style>
</head>
<body>
    <h2>🛠️ SERV RISC-V: Interactive Hardware Studio</h2>
    
    <div class="toolbar">
        <button id="bootBtn" class="btn-run">▶ Compile & Boot SoC</button>
        <button id="btnFast" class="sim-ctrl" disabled>⏩ Fast Run</button>
        <button id="btnSlow" class="sim-ctrl" disabled>▶ Slow Run</button>
        <button id="btnPause" class="sim-ctrl btn-pause" disabled>⏸ Pause</button>
        <button id="btnTickInst" class="sim-ctrl" disabled>⏭ Step (1 Inst)</button>
