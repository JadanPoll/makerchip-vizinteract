// ════════════════════════════════════════════════════════
// SECTION 15: TRAPS
// Pad layout: 5 words before nops = 20 bytes. Need handler at 80.
// Gap = 80-20 = 60 bytes = 15 nops.
// ════════════════════════════════════════════════════════
{
    name: "Trap ECALL: mcause=11, mepc=PC of ecall",
    // layout: addi(0) csrrw(4) ecall(8) sw(12) ebreak(16) [15 nops = 17..76] handler(80)
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0", // mtvec=80
        "ecall",              // byte 8 → trap
        "sw a1,256(zero)",    // byte 12 (after mret)
        "sw a2,260(zero)",    // byte 16
        "ebreak",             // byte 20
        ...Array(14).fill("nop"),  // bytes 24..79 (14 nops × 4 = 56 → total = 80)
        "handler:",           // byte 80
        "csrr a1,0x342",      // mcause (=11 for ecall M-mode)
        "csrr a2,0x341",      // mepc   (=8)
        "addi a3,a2,4","csrrw zero,0x341,a3",
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        return mem(cpu,64)===11 && mem(cpu,65)===8;
    }
},
{
    name: "Trap EBREAK: mcause=3, mepc=PC of ebreak",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        "ebreak",             // byte 8
        "sw a1,256(zero)",    // byte 12 (after mret)
        "sw a2,260(zero)",    // byte 16
        "ebreak",             // byte 20 (halt)
        ...Array(14).fill("nop"),
        "handler:",           // byte 80
        "csrr a1,0x342","csrr a2,0x341",
        "addi a3,a2,4","csrrw zero,0x341,a3",
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        return mem(cpu,64)===3 && mem(cpu,65)===8;
    }
},
{
    name: "Trap Illegal Instruction: mcause=2",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        ".word 0xFFFFFFFF",   // byte 8 → illegal
        "sw a1,256(zero)",    // byte 12 (after mret)
        "ebreak",             // byte 16
        ...Array(15).fill("nop"),
        "handler:",           // byte 80
        "csrr a1,0x342",
        "addi a2,zero,12","csrrw zero,0x341,a2", // skip illegal, go to sw
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        return mem(cpu,64)===2;
    }
},
{
    name: "Trap MRET: restores PC from mepc",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        "ecall",              // byte 8
        "addi a1,zero,42",   // byte 12: executed after MRET
        "sw a1,256(zero)","ebreak",
        ...Array(14).fill("nop"),
        "handler:",           // byte 80
        "addi a3,zero,12","csrrw zero,0x341,a3",  // mepc = 12
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        return mem(cpu,64)===42;
    }
},
{
    name: "Trap mstatus: MIE→0 on trap, MPIE set; MRET restores MIE",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        "csrrsi zero,0x300,8",   // mstatus.MIE = 1
        "ecall",                  // byte 12: MIE→0, MPIE→1
        "csrr a0,0x300",          // byte 16: read mstatus after MRET
        "sw a0,256(zero)",        // byte 20
        "ebreak",
        ...Array(13).fill("nop"),
        "handler:",               // byte 80
        "csrr a3,0x300",          // mid-trap mstatus (MIE=0, MPIE=1)
        "sw a3,260(zero)",
        "addi a4,zero,16","csrrw zero,0x341,a4",
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        const post_mret_mstatus = mem(cpu,64);  // MIE should be 1 (restored)
        const mid_trap_mstatus  = mem(cpu,65);  // MIE=0, MPIE=1
        return (post_mret_mstatus & 8) === 8 &&
               (mid_trap_mstatus & 8) === 0 &&
               (mid_trap_mstatus & 0x80) !== 0;
    }
},

// ════════════════════════════════════════════════════════
// SECTION 16: TIMER INTERRUPT
// ════════════════════════════════════════════════════════
{
    name: "Timer IRQ: taken when MIE=1 and MTIE=1",
    // handler at byte 80: 5 instr setup + 14 nops = 19 words = 76 bytes; handler at 80
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        "csrrsi zero,0x300,8",   // MIE=1
        "csrrsi zero,0x304,0x80",// mie.MTIE=1
        ...Array(10).fill("nop"),// spin — IRQ fires here
        "sw zero,256(zero)",     // should NOT execute if IRQ taken
        "ebreak",
        ...Array(7).fill("nop"), // pad
        "handler:",              // byte 80
        "addi a1,zero,99","sw a1,256(zero)","ebreak"
    ],
    verify(cpu) {
        cpu.run_with_timer_irq(400, 200000);
        return mem(cpu,64)===99;
    }
},
{
    name: "Timer IRQ: blocked when MIE=0 (normal flow completes)",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        // MIE deliberately left 0
        ...Array(10).fill("nop"),
        "addi a1,zero,42","sw a1,256(zero)","ebreak",
        ...Array(7).fill("nop"),
        "handler:",
        "addi a1,zero,99","sw a1,256(zero)","ebreak"
    ],
    verify(cpu) {
        cpu.run_with_timer_irq(200, 200000);
        return mem(cpu,64)===42;
    }
},

// ════════════════════════════════════════════════════════
// SECTION 17: PIPELINE / STATE MACHINE
// ════════════════════════════════════════════════════════
{
    name: "State: Back-to-back two-stage ops (two consecutive loads)",
    asm: ["addi a0,zero,10","addi a1,zero,20",
          "sw a0,256(zero)","sw a1,260(zero)",
          "lw a2,256(zero)","lw a3,260(zero)",
          "add a4,a2,a3","sw a4,264(zero)","ebreak"],
    verify(cpu) { cpu.run_cycles(100000); return mem(cpu,66)===30; }
},
{
    name: "State: Tight loop accumulator 1000 iterations",
    asm: ["addi a0,zero,1000","addi a1,zero,0",
          "loop:","addi a1,a1,1","addi a0,a0,-1","bne a0,zero,loop",
          "sw a1,256(zero)","ebreak"],
    verify(cpu) { cpu.run_cycles(500000); return mem(cpu,64)===1000; }
},

// ════════════════════════════════════════════════════════
// SECTION 18: EDGE CASES
// ════════════════════════════════════════════════════════
{
    // 0x00000000 = lb x0, 0(x0) — valid load to x0, discarded
    name: "Edge: All-zero instruction (lb x0,0(x0)) executes without trap",
    asm: [".word 0","addi a0,zero,42","sw a0,256(zero)","ebreak"],
    verify(cpu) { cpu.run_cycles(100000); return mem(cpu,64)===42; }
},
{
    // lw a0, 0(zero): reads instruction at byte 0
    // lw a0, 0(zero) = encI(0, 0, 2, 10, 0x03) = 0x00002503
    name: "Edge: Load from address 0x0 (reads own first instruction)",
    asm: ["lw a0,0(zero)","sw a0,256(zero)","ebreak"],
    verify(cpu) { cpu.run_cycles(100000); return mem(cpu,64)===0x00002503; }
},
{
    name: "Edge: All-ones instruction 0xFFFFFFFF → illegal → mcause=2",
    asm: [
        "addi a0,zero,80","csrrw zero,0x305,a0",
        ".word 0xFFFFFFFF",
        "sw a1,256(zero)","ebreak",
        ...Array(15).fill("nop"),
        "handler:",
        "csrr a1,0x342",
        "addi a2,zero,12","csrrw zero,0x341,a2",
        "mret"
    ],
    verify(cpu) {
        cpu.run_cycles(200000);
        return mem(cpu,64)===2;
    }
},
];

// ── C++ ENGINE ──────────────────────────────────────────────────────────────
const CPP_ENGINE = `
#include <cxxrtl/cxxrtl.h>
static char heap[262144];
static size_t heap_top = 0;
void* operator new(size_t n) {
    size_t a = (n+7)&~7u;
    if(heap_top+a>sizeof(heap)) return (void*)0;
    void* p = heap+heap_top; heap_top+=a; return p;
}
void* operator new[](size_t n) { return operator new(n); }
void operator delete(void*) noexcept {}
void operator delete[](void*) noexcept {}
void operator delete(void*,size_t) noexcept {}
void operator delete[](void*,size_t) noexcept {}
#undef assert
#define assert(x) ((void)0)
#include "sim.cpp"

cxxrtl_design::p_zero__soc dut;
uint32_t ram[8192];
int halted = 0;
uint32_t signal_flags = 0;   // bit8=ibus misalign, bit9=dbus misalign

static void bus_tick(int timer_irq_val) {
    dut.p_clk.data[0] = 0;
    dut.p_timer__irq.data[0] = timer_irq_val;

    uint32_t iadr = dut.p_ibus__adr.data[0];
    if(iadr & 3) signal_flags |= (1u<<8);
    int icyc = dut.p_ibus__cyc.data[0];
    if(icyc) {
        uint32_t inst = ram[(iadr>>2)&0x1FFF];
        if(inst == 0x00100073u) { halted = 1; }
        dut.p_ibus__rdt.data[0] = inst;
        dut.p_ibus__ack.data[0] = 1;
    } else {
        dut.p_ibus__ack.data[0] = 0;
    }

    uint32_t dadr = dut.p_dbus__adr.data[0];
    // Only flag dbus misalignment when dbus is active
    int dcyc = dut.p_dbus__cyc.data[0];
    if(dcyc && (dadr & 3)) signal_flags |= (1u<<9);
    if(dcyc) {
        uint32_t idx = (dadr>>2)&0x1FFF;
        if(dut.p_dbus__we.data[0]) {
            uint32_t dat = dut.p_dbus__dat.data[0];
            uint32_t sel = dut.p_dbus__sel.data[0];
            uint32_t mask = 0;
            if(sel&1) mask|=0x000000FFu;
            if(sel&2) mask|=0x0000FF00u;
            if(sel&4) mask|=0x00FF0000u;
            if(sel&8) mask|=0xFF000000u;
            ram[idx] = (ram[idx] & ~mask) | (dat & mask);
        } else {
            dut.p_dbus__rdt.data[0] = ram[idx];
        }
        dut.p_dbus__ack.data[0] = 1;
    } else {
        dut.p_dbus__ack.data[0] = 0;
    }

    dut.p_clk.data[0] = 1; dut.step();
    dut.p_ibus__ack.data[0] = 0;
    dut.p_dbus__ack.data[0] = 0;
    dut.step();
}

extern "C" {
    __attribute__((export_name("init_cpu"))) void init_cpu() {
        for(int i=0;i<8192;i++) ram[i]=0;
        signal_flags = 0;
        dut.reset();
        dut.p_rst__n.data[0] = 0;
        dut.p_timer__irq.data[0] = 0;
        for(int i=0;i<200;i++){
            dut.p_clk.data[0]=0; dut.step();
            dut.p_clk.data[0]=1; dut.step();
        }
        dut.p_rst__n.data[0] = 1;
        dut.step();
        halted = 0;
    }

    __attribute__((export_name("load_inst"))) void load_inst(int word_addr, uint32_t inst) {
        ram[word_addr] = inst;
    }

    __attribute__((export_name("read_mem"))) uint32_t read_mem(int word_addr) {
        return ram[word_addr];
    }

    __attribute__((export_name("get_flags"))) uint32_t get_flags() {
        return signal_flags;
    }

    __attribute__((export_name("run_cycles"))) int run_cycles(int max_cycles) {
        int c = 0;
        while(c < max_cycles && !halted) {
            bus_tick(0);
            c++;
        }
        return c;
    }

    __attribute__((export_name("run_with_timer_irq"))) int run_with_timer_irq(int assert_at, int max_cycles) {
        int c = 0;
        while(c < max_cycles && !halted) {
            bus_tick(c >= assert_at ? 1 : 0);
            c++;
        }
        return c;
    }

    __attribute__((export_name("run_reset_check"))) uint32_t run_reset_check() {
        dut.reset();
        dut.p_rst__n.data[0] = 0;
        dut.p_timer__irq.data[0] = 0;
        uint32_t cyc_high = 0;
        for(int i=0;i<50;i++){
            dut.p_clk.data[0]=0; dut.step();
            if(dut.p_ibus__cyc.data[0]) cyc_high++;
            dut.p_clk.data[0]=1; dut.step();
        }
        // restore
        dut.p_rst__n.data[0] = 1; dut.step();
        halted = 0;
        return cyc_high;
    }
}
`;

const wrapperVerilog = `
module zero_soc (
    input  logic        clk,
    input  logic        rst_n,
    input  logic        timer_irq,
    output logic [31:0] ibus_adr,
    output logic        ibus_cyc,
    input  logic [31:0] ibus_rdt,
    input  logic        ibus_ack,
    output logic [31:0] dbus_adr,
    output logic [31:0] dbus_dat,
    output logic [3:0]  dbus_sel,
    output logic        dbus_we,
    output logic        dbus_cyc,
    input  logic [31:0] dbus_rdt,
    input  logic        dbus_ack
);
    serv_rf_top #(.RESET_PC(32'h0000_0000)) cpu (
        .clk(clk), .i_rst(~rst_n), .i_timer_irq(timer_irq),
        .o_ibus_adr(ibus_adr), .o_ibus_cyc(ibus_cyc),
        .i_ibus_rdt(ibus_rdt), .i_ibus_ack(ibus_ack),
        .o_dbus_adr(dbus_adr), .o_dbus_dat(dbus_dat),
        .o_dbus_sel(dbus_sel), .o_dbus_we(dbus_we),
        .o_dbus_cyc(dbus_cyc), .i_dbus_rdt(dbus_rdt),
        .i_dbus_ack(dbus_ack)
    );
endmodule`;

// ── UI ───────────────────────────────────────────────────────────────────────
function buildUI() {
    const grid = document.getElementById('testGrid');
    grid.innerHTML = '';
    TESTS.forEach((t, i) => {
        const card = document.createElement('div');
        card.className = 'test-card';
        card.id = `card-${i}`;
        card.innerHTML = `<h3>${i+1}. ${t.name}</h3>
            <div class="asm">${t.asm.join('\n')}</div>
            <div class="result" id="res-${i}">Waiting...</div>`;
        grid.appendChild(card);
    });
}

async function runSuite() {
    document.getElementById('buildBtn').disabled = true;
    logEl.innerHTML = '';
    sumEl.textContent = '';
    buildUI();

    try {
        const dec = new TextDecoder();
        const toStr = v => v ? (typeof v === 'string' ? v : dec.decode(v)) : '';

        log('Fetching SERV RTL from jsDelivr...');
        const servFiles = [
            'serv_aligner.v','serv_alu.v','serv_bufreg.v','serv_bufreg2.v',
            'serv_compdec.v','serv_csr.v','serv_ctrl.v','serv_debug.v',
            'serv_decode.v','serv_immdec.v','serv_mem_if.v','serv_rf_if.v',
            'serv_rf_ram_if.v','serv_rf_ram.v','serv_rf_top.v','serv_state.v','serv_top.v'
        ];
        const vfs = { 'input.v': wrapperVerilog };
        await Promise.all(servFiles.map(async f => {
            const r = await fetch(`https://cdn.jsdelivr.net/gh/olofk/serv@main/rtl/${f}`);
            if (!r.ok) throw new Error(`Failed to fetch ${f}`);
            vfs[f] = await r.text();
        }));
        log('RTL fetched ✓', '#69db7c');

        log('Running Yosys synthesis...', '#ffd43b');
        const cmds = [
            'read_verilog -sv input.v',
            ...servFiles.map(f => `read_verilog -sv ${f}`),
            'prep -top zero_soc',
            'write_cxxrtl sim.cpp'
        ].join('; ');
        const yOut = await runYosys(['-p', cmds], vfs);
        const simCpp = toStr(yOut['sim.cpp']);
        if (!simCpp) throw new Error('Yosys produced no sim.cpp');
        log('Synthesis complete ✓', '#69db7c');

        log('Fetching CXXRTL header...', '#ffd43b');
        const hRes = await fetch('https://cdn.jsdelivr.net/gh/JadanPoll/makerchip-vizinteract@main/cxxrtl_bare_baremetal.h');
        const header = await hRes.text();

        log('Compiling C++ → WebAssembly...', '#ffd43b');
        const cOut = await runClang(
            ['clang++','-std=c++17','-O2','-I/',
             '--target=wasm32','-nostdlib','-nostdinc',
             '-fno-exceptions','-fno-rtti',
             '-Wl,--no-entry','-Wl,--allow-undefined',
             'driver.cpp','-o','sim.wasm'],
            { 'driver.cpp': CPP_ENGINE, 'sim.cpp': simCpp, 'cxxrtl': { 'cxxrtl.h': header } }
        );
        if (!cOut['sim.wasm']) throw new Error('Clang produced no sim.wasm');
        log('Compilation complete ✓', '#69db7c');

        const { instance } = await WebAssembly.instantiate(
            cOut['sim.wasm'],
            { env: new Proxy({}, { get: () => () => 0 }) }
        );
        const cpu = instance.exports;
        log(`\nWasm ready. Running ${TESTS.length} tests...\n`, '#69db7c');

        let passed = 0, failed = 0;

        for (let i = 0; i < TESTS.length; i++) {
            const t = TESTS[i];
            const resEl = document.getElementById(`res-${i}`);
            resEl.className = 'result running';
            resEl.textContent = 'Running...';
            await new Promise(r => setTimeout(r, 0)); // yield to browser

            try {
                // Assemble
                const words = ASM(t.asm);
                // Always init + load before verify
                cpu.init_cpu();
                words.forEach((w, idx) => cpu.load_inst(idx, w));
                // verify() is responsible for calling run_cycles or specialized runners
                const ok = t.verify(cpu);
                if (ok) {
                    resEl.className = 'result pass';
                    resEl.textContent = 'PASS ✓';
                    passed++;
                    log(`  PASS  [${i+1}] ${t.name}`, '#69db7c');
                } else {
                    resEl.className = 'result fail';
                    resEl.textContent = 'FAIL ✗';
                    failed++;
                    log(`  FAIL  [${i+1}] ${t.name}`, '#f97171');
                }
            } catch(e) {
                resEl.className = 'result fail';
                resEl.textContent = `ERROR: ${e.message}`;
                failed++;
                log(`  ERR   [${i+1}] ${t.name}: ${e.message}`, '#f97171');
            }
        }

        const color = failed === 0 ? '#69db7c' : '#ffd43b';
        const msg = `\n══ GAUNTLET COMPLETE: ${passed}/${TESTS.length} passed, ${failed} failed ══`;
        log(msg, color);
        sumEl.style.color = color;
        sumEl.textContent = `${passed}/${TESTS.length} passed — ${failed} failed`;

    } catch(e) {
        log(`\nFATAL: ${e.message}\n${e.stack||''}`, '#f97171');
    } finally {
        document.getElementById('buildBtn').disabled = false;
    }
}

document.getElementById('buildBtn').onclick = runSuite;
buildUI();
</script>
