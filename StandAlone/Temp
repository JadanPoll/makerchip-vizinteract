// ── ASSEMBLER ──────────────────────────────────────────────────────────────
const ASM = (() => {
    const REG = {
        x0:0,zero:0,ra:1,sp:2,gp:3,tp:4,t0:5,t1:6,t2:7,
        s0:8,fp:8,s1:9,a0:10,a1:11,a2:12,a3:13,a4:14,a5:15,
        a6:16,a7:17,s2:18,s3:19,s4:20,s5:21,s6:22,s7:23,
        s8:24,s9:25,s10:26,s11:27,t3:28,t4:29,t5:30,t6:31
    };
    const pr = r => REG[r.replace(/[,]/g,'').trim()] ?? 0;
    const pi = i => parseInt(i.replace(/[,]/g,'').trim());
    const encR = (f7,rs2,rs1,f3,rd,op) => ((f7<<25)|(rs2<<20)|(rs1<<15)|(f3<<12)|(rd<<7)|op)>>>0;
    const encI = (imm,rs1,f3,rd,op) => (((imm&0xFFF)<<20)|(rs1<<15)|(f3<<12)|(rd<<7)|op)>>>0;
    const encS = (imm,rs2,rs1,f3,op) => ((((imm>>5)&0x7F)<<25)|(rs2<<20)|(rs1<<15)|(f3<<12)|((imm&0x1F)<<7)|op)>>>0;
    const encB = (imm,rs2,rs1,f3,op) => ((((imm>>12)&1)<<31)|(((imm>>5)&0x3F)<<25)|(rs2<<20)|(rs1<<15)|(f3<<12)|(((imm>>1)&0xF)<<8)|(((imm>>11)&1)<<7)|op)>>>0;
    const encU = (imm,rd,op) => ((imm&0xFFFFF000)|(rd<<7)|op)>>>0;
    const encJ = (imm,rd,op) => ((((imm>>20)&1)<<31)|(((imm>>1)&0x3FF)<<21)|(((imm>>11)&1)<<20)|(((imm>>12)&0xFF)<<12)|(rd<<7)|op)>>>0;

    return function assemble(lines) {
        const labels = {};
        let pc = 0;
        // pass 1: collect labels
        for (const line of lines) {
            let l = line.split('#')[0].trim();
            if (!l) continue;
            if (l.includes(':')) {
                labels[l.split(':')[0].trim()] = pc;
                l = l.split(':').slice(1).join(':').trim();
            }
            if (l) pc += 4;
        }
        // pass 2: emit
        pc = 0;
        const words = [];
        for (const line of lines) {
            let l = line.split('#')[0].trim();
            if (!l) continue;
            if (l.includes(':')) l = l.split(':').slice(1).join(':').trim();
            if (!l) continue;
            const parts = l.split(/[\s,()]+/).filter(x => x);
            const op = parts[0];
            const lbl = name => isNaN(parseInt(name)) ? (labels[name] - pc) : parseInt(name);
            let w = 0;
            switch(op) {
                case 'addi':  w = encI(pi(parts[3]), pr(parts[2]), 0, pr(parts[1]), 0x13); break;
                case 'slti':  w = encI(pi(parts[3]), pr(parts[2]), 2, pr(parts[1]), 0x13); break;
                case 'sltiu': w = encI(pi(parts[3]), pr(parts[2]), 3, pr(parts[1]), 0x13); break;
                case 'xori':  w = encI(pi(parts[3]), pr(parts[2]), 4, pr(parts[1]), 0x13); break;
                case 'ori':   w = encI(pi(parts[3]), pr(parts[2]), 6, pr(parts[1]), 0x13); break;
                case 'andi':  w = encI(pi(parts[3]), pr(parts[2]), 7, pr(parts[1]), 0x13); break;
                case 'slli':  w = encI((pi(parts[3])&0x1F),       pr(parts[2]), 1, pr(parts[1]), 0x13); break;
                case 'srli':  w = encI((pi(parts[3])&0x1F),       pr(parts[2]), 5, pr(parts[1]), 0x13); break;
                case 'srai':  w = encI((pi(parts[3])&0x1F)|0x400, pr(parts[2]), 5, pr(parts[1]), 0x13); break;
                case 'add':   w = encR(0,    pr(parts[3]), pr(parts[2]), 0, pr(parts[1]), 0x33); break;
                case 'sub':   w = encR(0x20, pr(parts[3]), pr(parts[2]), 0, pr(parts[1]), 0x33); break;
                case 'sll':   w = encR(0,    pr(parts[3]), pr(parts[2]), 1, pr(parts[1]), 0x33); break;
                case 'slt':   w = encR(0,    pr(parts[3]), pr(parts[2]), 2, pr(parts[1]), 0x33); break;
                case 'sltu':  w = encR(0,    pr(parts[3]), pr(parts[2]), 3, pr(parts[1]), 0x33); break;
                case 'xor':   w = encR(0,    pr(parts[3]), pr(parts[2]), 4, pr(parts[1]), 0x33); break;
                case 'srl':   w = encR(0,    pr(parts[3]), pr(parts[2]), 5, pr(parts[1]), 0x33); break;
                case 'sra':   w = encR(0x20, pr(parts[3]), pr(parts[2]), 5, pr(parts[1]), 0x33); break;
                case 'or':    w = encR(0,    pr(parts[3]), pr(parts[2]), 6, pr(parts[1]), 0x33); break;
                case 'and':   w = encR(0,    pr(parts[3]), pr(parts[2]), 7, pr(parts[1]), 0x33); break;
                case 'lui':   w = encU(pi(parts[2])<<12, pr(parts[1]), 0x37); break;
                case 'auipc': w = encU(pi(parts[2])<<12, pr(parts[1]), 0x17); break;
                case 'lb':    w = encI(pi(parts[2]), pr(parts[3]), 0, pr(parts[1]), 0x03); break;
                case 'lh':    w = encI(pi(parts[2]), pr(parts[3]), 1, pr(parts[1]), 0x03); break;
                case 'lw':    w = encI(pi(parts[2]), pr(parts[3]), 2, pr(parts[1]), 0x03); break;
                case 'lbu':   w = encI(pi(parts[2]), pr(parts[3]), 4, pr(parts[1]), 0x03); break;
                case 'lhu':   w = encI(pi(parts[2]), pr(parts[3]), 5, pr(parts[1]), 0x03); break;
                case 'sb':    w = encS(pi(parts[2]), pr(parts[1]), pr(parts[3]), 0, 0x23); break;
                case 'sh':    w = encS(pi(parts[2]), pr(parts[1]), pr(parts[3]), 1, 0x23); break;
                case 'sw':    w = encS(pi(parts[2]), pr(parts[1]), pr(parts[3]), 2, 0x23); break;
                case 'beq':   w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 0, 0x63); break;
                case 'bne':   w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 1, 0x63); break;
                case 'blt':   w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 4, 0x63); break;
                case 'bge':   w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 5, 0x63); break;
                case 'bltu':  w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 6, 0x63); break;
                case 'bgeu':  w = encB(lbl(parts[3]), pr(parts[2]), pr(parts[1]), 7, 0x63); break;
                case 'jal':   w = encJ(lbl(parts[2]), pr(parts[1]), 0x6f); break;
                case 'jalr':  w = encI(pi(parts[3]), pr(parts[2]), 0, pr(parts[1]), 0x67); break;
                case 'j':     w = encJ(lbl(parts[1]), 0, 0x6f); break;
                case 'csrrw':  w = encI(pi(parts[2]), pr(parts[3]), 1, pr(parts[1]), 0x73); break;
                case 'csrrs':  w = encI(pi(parts[2]), pr(parts[3]), 2, pr(parts[1]), 0x73); break;
                case 'csrrc':  w = encI(pi(parts[2]), pr(parts[3]), 3, pr(parts[1]), 0x73); break;
                case 'csrrwi': w = encI(pi(parts[2]), pi(parts[3])&0x1F, 5, pr(parts[1]), 0x73); break;
                case 'csrrsi': w = encI(pi(parts[2]), pi(parts[3])&0x1F, 6, pr(parts[1]), 0x73); break;
                case 'csrrci': w = encI(pi(parts[2]), pi(parts[3])&0x1F, 7, pr(parts[1]), 0x73); break;
                case 'csrr':   w = encI(pi(parts[2]), 0, 2, pr(parts[1]), 0x73); break;
                case 'ecall':  w = 0x00000073; break;
                case 'ebreak': w = 0x00100073; break;
                case 'mret':   w = 0x30200073; break;
                case 'nop':    w = 0x00000013; break;
                case '.word':  w = (pi(parts[1]))>>>0; break;
                default: throw new Error('Unknown opcode: ' + op);
            }
            words.push(w);
            pc += 4;
        }
        return words;
    };
})();

// ── SAFE MEMORY HELPER ──────────────────────────────────────────────────────
// Used in verify functions: mem(cpu, wordIndex) -> uint32
function mem(cpu, idx) { return cpu.read_mem(idx) >>> 0; }

