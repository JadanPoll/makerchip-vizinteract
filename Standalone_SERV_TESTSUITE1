        #global-log { background: #111; border: 1px solid #2a3050; border-radius: 6px; padding: 12px; height: 200px; overflow-y: auto; font-size: 0.82rem; white-space: pre-wrap; margin-top: 16px; }
        .ok { color: #69db7c; } .err { color: #f97171; } .warn { color: #ffd43b; } .info { color: #9cdcfe; }
