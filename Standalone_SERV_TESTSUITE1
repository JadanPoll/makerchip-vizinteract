__attribute__((export_name("t23"))) int t23() { ram[0] = 0x00A00513; ram[1] = 0x800005B7; ram[2] = 0x00A5A023; ram[3] = 0x0000006F; for(int i=4;i<4096;i++) ram[i]=0x00000013; do_reset(); int cycles=0; for(int c=0;c<3000;c++){ clk_lo(); if(dut.p_dbus__cyc.data[0] && dut.p_dbus__we.data[0]) return (cycles>60 && cycles<120) ? 1 : 0; tick_with_bus(); cycles++; } return 0; }

