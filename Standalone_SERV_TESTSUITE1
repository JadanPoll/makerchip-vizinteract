__attribute__((export_name("t21"))) int t21() { ram[0] = 0x00100013; ram[1] = 0x800005B7; ram[2] = 0x0005A023; ram[3] = 0x0000006F; for(int i=4;i<4096;i++) ram[i]=0x00000013; do_reset(); for(int c=0;c<2000;c++){ clk_lo(); if(dut.p_dbus__cyc.data[0] && dut.p_dbus__we.data[0]){ uint32_t dat = dut.p_dbus__dat.data[0]; return 1 | ((dat&0xFFFF)<<16); } tick_with_bus(); } return 0; }

