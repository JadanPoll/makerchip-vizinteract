// ============================================================
// hdmi_scaffold.tlv
// FROZEN scaffold for HDMI Text Controller — ECE 385 Lab 7.1
//
// Imported by hdmi_text_controller_makerchip.tlv via:
//   m5_sv_get_url([' ... raw GitHub URL ... '])
//
// Contains (do not edit during iterative core development):
//   • vga_controller SV module  (synthesis reference)
//   • font_rom SV module        (128 chars × 16 rows, 8-bit)
//   • VGA counters + sync       (inside |vga @1, scaffold portion)
//   • |axi stimulus pipeline    (COLOR reg + VRAM word fill)
//   • /vram[600:0] hierarchy    (601 × 32-bit words)
//   • /viz virtual CRT monitor + signal inspector + AXI logic analyzer
//
// Signal interface to core (|vga @1):
//   PROVIDED by scaffold (read freely in core):
//     $reset  $drawX[9:0]  $drawY[9:0]  $active
//     $pclk_en  $hc[9:0]  $vc[9:0]
//     $hsync  $vsync  $frame_cnt[31:0]
//     /vram[$word_addr]$word_data   (VRAM read — dynamic index)
//     /vram[10'd600]$word_data      (COLOR register)
//   EXPECTED from core (consumed by viz):
//     $word_addr[9:0]  $byte_sel[1:0]
//     $exact_char[7:0]
//     $font_addr[10:0]  $font_data[7:0]
//     $draw_fg  $pv
//     $fg_r[3:0]  $fg_g[3:0]  $fg_b[3:0]
//     $bg_r[3:0]  $bg_g[3:0]  $bg_b[3:0]
//     $red[3:0]   $green[3:0] $blue[3:0]
// ============================================================
   // ============================================================
   // INLINE MODULE 1: VGA Controller (verbatim from lab provided)
   // 640x480 @ ~60Hz, 25MHz pixel clock
   // hpixels=799, vlines=524
   // hsync: pixels 656-752 (active low)
   // vsync: lines 490-491 (active low)
   // active region: hc<640, vc<480
   // ============================================================
   module vga_controller (
      input        pixel_clk,
                   reset,
      output logic hs,
                   vs,
                   active_nblank,
                   sync,
      output [9:0] drawX,
                   drawY
   );
      parameter [9:0] hpixels = 10'b1100011111; // 799
      parameter [9:0] vlines  = 10'b1000001100; // 524
      logic [9:0] hc, vc;
      logic display;
      assign sync = 1'b0;

      always_ff @(posedge pixel_clk or posedge reset) begin : counter_proc
         if (reset) begin hc <= 0; vc <= 0; end
         else if (hc == hpixels) begin
            hc <= 0;
            vc <= (vc == vlines) ? 0 : vc + 1;
         end else hc <= hc + 1;
      end

      assign drawX = hc;
      assign drawY = vc;

      always_ff @(posedge reset or posedge pixel_clk) begin : hsync_proc
         if (reset) hs <= 0;
         else hs <= !((hc+1 >= 10'd656) && (hc+1 < 10'd752));
      end

      always_ff @(posedge reset or posedge pixel_clk) begin : vsync_proc
         if (reset) vs <= 0;
         else vs <= !((vc+1 == 10'd490) || (vc+1 == 10'd491));
      end

      always_comb begin
         display = !((hc >= 10'd640) || (vc >= 10'd480));
      end
      assign active_nblank = display;
   endmodule

   // ============================================================
   // INLINE MODULE 2: Font ROM (verbatim from lab provided)
   // 128 characters x 16 rows = 2048 entries, 8 bits wide
   // addr[10:4] = character code (7-bit ASCII)
   // addr[3:0]  = row within character (0=top, 15=bottom)
   // data[7]    = leftmost pixel (MSB first)
   // Combinational output (no registered latency)
   // ============================================================
   module font_rom (
      input  [10:0] addr,
      output [7:0]  data
   );
      parameter ADDR_WIDTH = 11;
      parameter DATA_WIDTH =  8;
